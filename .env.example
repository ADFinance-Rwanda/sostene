# =============================================================================
# Task Manager — environment variables
#
# Copy this file to `.env` (`cp .env.example .env`) before running
# `docker compose up --build`. The defaults below are intended for LOCAL
# DOCKER COMPOSE DEVELOPMENT ONLY. They are committed to the repo on purpose
# so reviewers can run the project without guessing.
#
# =============================================================================

# --- General ---
NODE_ENV=development

# --- Host port mappings (change if any port is already in use on your host) ---
FRONTEND_PORT=3000
BACKEND_PORT=5000
POSTGRES_PORT=5432
REDIS_PORT=6379
KEYCLOAK_PORT=8080

# --- PostgreSQL ---
POSTGRES_USER=taskmanager
POSTGRES_PASSWORD=local_pg_taskmgr_dev
POSTGRES_DB=taskmanager
# Separate logical database used by Keycloak inside the same Postgres instance.
KEYCLOAK_DB=keycloak

# --- Redis ---
REDIS_PASSWORD=local_redis_taskmgr_dev

# --- Keycloak admin console (http://localhost:${KEYCLOAK_PORT}) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin


KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=task-manager

# --- Frontend (Vite build-time vars; injected via docker-compose build args) ---
VITE_API_BASE_URL=http://localhost:5000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=task-manager
VITE_KEYCLOAK_CLIENT_ID=taskmanager-frontend

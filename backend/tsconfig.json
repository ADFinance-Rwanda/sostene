{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "lib": [
            "ES6"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,

        // debugging options
        "sourceMap": true,
        "inlineSourceMap": false,
        "inlineSources": true,
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}